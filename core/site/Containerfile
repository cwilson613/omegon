FROM docker.io/library/nginx:1-alpine

# Remove default config and content
RUN rm -rf /etc/nginx/conf.d/default.conf /usr/share/nginx/html/*

# Add our config
COPY nginx.conf /etc/nginx/conf.d/omegon.conf

# Landing page at /
COPY index.html /usr/share/nginx/html/index.html

# Install script at /install.sh
# Note: install.sh is copied into site/ by CI before build
COPY install.sh /usr/share/nginx/html/install.sh

# Astro-built docs at /docs/, /changelog/, etc.
# Note: docs-dist/ is copied into site/ by CI after Astro build
COPY docs-dist/ /usr/share/nginx/html/

# nginx runs as non-root (uid 101) via the parent image
EXPOSE 80
